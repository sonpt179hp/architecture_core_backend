{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.AspNetCore": "Information",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=govdocs;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "Redis": {
    "Host": "localhost",
    "Port": 6379,
    "Password": null,
    "Database": 0,
    "Ssl": false,
    "InstanceName": "gov-docs:",
    "ConnectTimeoutMs": 5000,
    "AbortOnConnectFail": false
  },
  "Jwt": {
    "Issuer": "gov-docs",
    "Audience": "gov-docs",
    "SecretKey": "dev-secret-key-change-in-production-32chars-minimum",
    "ExpiryMinutes": 1440
  }
}
